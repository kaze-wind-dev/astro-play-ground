<style lang="scss">
  .wrapper {
    width: 9em;
    font-size: var(--font-size-2xl);
  }

  .slide-opacity-60 {
    fill: color-mix(in srgb, var(--black-color) 60%, transparent 0%);
  }

  .slide-opacity-100 {
    fill: var(--black-color);
  }
</style>

<script>
  import { gsap } from 'gsap';

  function init() {
    gsap.set('.slide-opacity-100, .slide-opacity-60', {
      scaleX: 0,
    });
    let tl = gsap.timeline();
    tl.to('.slide-opacity-60', {
      scaleX: 1,
      duration: 0.4,
      ease: 'power3.in',
    }).to(
      '.slide-opacity-100',
      {
        scaleX: 1,
        duration: 0.4,
        ease: 'power3.in',
      },
      '+=.08',
    );
  }
  init();
</script>
