---
type Props = {
  size?: number;
  class?: string;
};
const { size = 24, class: className, ...props } = Astro.props;
---

<svg
  class:list={['icon', className ?? '']}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 -960 960 960"
  width={size}
  height={size}
  fill="currentColor"
  aria-hidden="true"
  {...props}
>
  <path d="M660-240v-480h80v480h-80Zm-440 0v-480l360 240-360 240Z"></path>
</svg>

<style lang="scss">
  .icon {
    display: inline-block;
    flex-shrink: 0;
  }
</style>
