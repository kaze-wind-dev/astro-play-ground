<!-- アニメ用フック: data-controllable / data-controllable-card --><!-- 想定: card をループ再生する Animation を保持し、Header のコントローラと接続する -->
<section class="controllable" data-controllable>
  <div class="head">
    <p class="eyebrow">01 — Controllable</p>
    <h2 class="headline">動きを、あとから操作する</h2>
    <p class="lead">
      element.animate() は Animation オブジェクトを返します。<br />
      再生・一時停止・逆再生・速度変更を、動いている最中でも呼び出せます。<br />
      下のボタンで試してみてください。
    </p>
    <p class="note">
      Play / Pause / Reverse / Rate。CSS
      のアニメーションでは、ここまで細かく制御できません。
    </p>
  </div>

  <div class="stage">
    <div class="card" data-controllable-card></div>
  </div>

  <div class="controls" role="group" aria-label="再生コントロール">
    <button type="button" class="ctrl" data-action="play">Play</button>
    <button type="button" class="ctrl" data-action="pause">Pause</button>
    <button type="button" class="ctrl" data-action="reverse">Reverse</button>
    <button type="button" class="ctrl" data-action="rate" data-rate
      >Rate ×1</button
    >
  </div>
</section>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixin' as *;

  .controllable {
    min-height: 100svh;
    display: grid;
    align-content: center;
    gap: var(--spacing-3xl);
    padding-inline: 5%;
  }

  .eyebrow {
    font-family: var(--font-secondary);
    font-size: var(--fz-sm);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--wd-color-primary);
    margin-block-end: var(--spacing-md);
  }

  .headline {
    font-size: var(--heading-2);
    font-weight: 700;
    line-height: 1.3;
    margin-block-end: var(--spacing-md);
  }

  .lead {
    font-size: var(--fz-md);
    line-height: 1.8;
    color: var(--wd-color-on-surface-variant);
  }

  .note {
    font-family: var(--font-secondary);
    font-size: var(--fz-xs);
    letter-spacing: 0.1em;
    color: var(--wd-color-outline);
    margin-block-start: var(--spacing-md);
  }

  .stage {
    display: grid;
    place-items: center;
    min-height: 40vh;
  }

  .card {
    width: clamp(120px, 30vw, 220px);
    aspect-ratio: 3 / 4;
    border-radius: 1rem;
    background: linear-gradient(
      150deg,
      var(--wd-color-primary),
      var(--wd-color-tertiary)
    );
    box-shadow: 0 1.5rem 3rem
      color-mix(in srgb, var(--wd-color-shadow) 18%, transparent);
  }

  .controls {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-md);
  }

  .ctrl {
    font-family: var(--font-secondary);
    font-size: var(--fz-sm);
    letter-spacing: 0.1em;
    padding: var(--spacing-sm) var(--spacing-lg);
    border-radius: 999px;
    border: 1px solid var(--wd-color-outline);
    background-color: transparent;
    color: var(--wd-color-on-surface);
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;

    &:hover {
      border-color: var(--wd-color-primary);
      color: var(--wd-color-primary);
    }

    &:active {
      background-color: color-mix(
        in srgb,
        var(--wd-color-primary) 12%,
        transparent
      );
    }
  }
</style>

<script>
  import { onMotionChange } from '../../scripts/motion';

  // ボタンから play / pause / reverse / playbackRate でアニメーション制御
  const card = document.querySelector<HTMLElement>('[data-controllable-card]');
  const buttons = document.querySelectorAll<HTMLButtonElement>('.ctrl');
  const rateButton = document.querySelector<HTMLButtonElement>('[data-rate]');

  if (card) {
    // ループし続ける動き。これを1本の Animation として保持する。
    const anim = card.animate(
      [
        { transform: 'translateY(0) rotate(0deg) scale(1)' },
        { transform: 'translateY(-48px) rotate(180deg) scale(1.12)' },
        { transform: 'translateY(0) rotate(360deg) scale(1)' },
      ],
      {
        duration: 3200,
        iterations: Infinity,
        easing: 'ease-in-out',
      },
    );

    // isMotion に追従: 停止中(false)はループを止め、再生中(true)は動かす。
    // 登録直後にも一度呼ばれるので、初期状態（reduced なら静止）もこれで決まる。
    onMotionChange((isMotion) => {
      if (isMotion) anim.play();
      else anim.pause();
    });

    // Rate は候補を巡回させる
    const rates = [0.5, 1, 2];
    let rateIndex = 1;

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        switch (button.dataset.action) {
          case 'play':
            anim.play();
            break;
          case 'pause':
            anim.pause();
            break;
          case 'reverse':
            anim.reverse();
            break;
          case 'rate':
            rateIndex = (rateIndex + 1) % rates.length;
            anim.playbackRate = rates[rateIndex];
            if (rateButton)
              rateButton.textContent = `Rate ×${rates[rateIndex]}`;
            break;
        }
      });
    });
  }
</script>
