<!-- アニメ用フック: data-scroll-linked（スクロール量の算出対象） --><!-- 想定: dial / thumb の Animation を pause() し、scroll で currentTime を打つ --><!-- セクション全体を背高にし、中身を sticky で貼り付けてスクロール尺を稼ぐ -->
<section class="scroll-linked" data-scroll-linked>
  <div class="sticky">
    <div class="head">
      <p class="eyebrow">03 — Scroll-linked</p>
      <h2 class="headline">スクロールに合わせて再生する</h2>
      <p class="lead">
        currentTime をスクロール量に結びつけると、<br />
        ページを進めた分だけアニメーションが進みます。
      </p>
    </div>

    <div class="stage">
      <div class="dial" data-dial></div>
      <div class="track">
        <span class="thumb" data-thumb></span>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixin' as *;

  .scroll-linked {
    // スクロール尺。getBoundingClientRect().height がここで効く。
    height: 250vh;
    padding-inline: 5%;
  }

  .sticky {
    position: sticky;
    top: 0;
    min-height: 100svh;
    display: grid;
    align-content: center;
    gap: var(--spacing-5xl);
  }

  .eyebrow {
    font-family: var(--font-secondary);
    font-size: var(--fz-sm);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--wd-color-primary);
    margin-block-end: var(--spacing-md);
  }

  .headline {
    font-size: var(--heading-2);
    font-weight: 700;
    line-height: 1.3;
    margin-block-end: var(--spacing-md);
  }

  .lead {
    font-size: var(--fz-md);
    line-height: 1.8;
    color: var(--wd-color-on-surface-variant);
  }

  .stage {
    display: grid;
    justify-items: center;
    gap: var(--spacing-3xl);
  }

  .dial {
    width: clamp(120px, 26vw, 200px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: conic-gradient(
      var(--wd-color-primary),
      var(--wd-color-tertiary),
      var(--wd-color-primary)
    );
  }

  .track {
    width: min(600px, 80%);
    height: 8px;
    border-radius: 5px;
    background-color: var(--wd-color-surface-variant);
    overflow: hidden;
  }

  .thumb {
    display: block;
    width: 100%;
    height: 100%;
    background-color: var(--wd-color-primary);

    // scaleX(0) → scaleX(1) を currentTime で打つ想定。
    transform-origin: left;
    transform: scaleX(0); // 出現前の初期状態（進捗 0）
  }
</style>

<script>
  import { getIsMotion, onMotionChange } from '../../scripts/motion';

  // スクロール量を currentTime に変換して、pause() した Animation を手で送る。
  // 再生ヘッド = スクロール位置。dial と thumb を同じ進捗 p で同期させる。
  const section = document.querySelector<HTMLElement>('[data-scroll-linked]');
  const dial = document.querySelector<HTMLElement>('[data-dial]');
  const thumb = document.querySelector<HTMLElement>('[data-thumb]');

  // duration は「尺の単位」でしかない。実時間では再生しないので任意でよい。
  const DURATION = 1000;

  const dialAnim = dial?.animate(
    { rotate: ['0deg', '360deg'] },
    { duration: DURATION, easing: 'linear', fill: 'both' },
  );

  const thumbAnim = thumb?.animate(
    { transform: ['scaleX(0)', 'scaleX(1)'] },
    { duration: DURATION, easing: 'linear', fill: 'both' },
  );

  // 自動再生を止め、以降は currentTime を手打ちする。
  dialAnim?.pause();
  thumbAnim?.pause();

  let ticking = false;

  function update() {
    if (!section || !dialAnim || !thumbAnim) return;
    const viewport = window.visualViewport;
    if (!viewport) return;

    const viewportHeight = viewport.height;
    const rect = section.getBoundingClientRect();

    // sticky が貼り付いている間、top は 0 →  -(section高 - viewport高) と動く。
    // その移動量に対する進捗を 0〜1 に正規化する。
    const range = rect.height - viewportHeight;
    const raw = -rect.top / range;
    const p = Math.min(1, Math.max(0, raw));

    // 進捗バー(thumb)は情報なので常に追従。装飾の dial 回転は
    // isMotion が false のとき止めておく（0 に固定）。
    thumbAnim.currentTime = p * DURATION;
    dialAnim.currentTime = getIsMotion() ? p * DURATION : 0;
  }

  addEventListener('scroll', () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      update();
      ticking = false;
    });
  });

  // スクロールしていなくてもトグルに反応できるよう、変化時に打ち直す。
  onMotionChange(() => update());

  update(); // 初期表示（リロード位置に追従）
</script>
