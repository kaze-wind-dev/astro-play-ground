---
import PlayIcon from '../components/icon/PlayIcon.astro';
import PauseIcon from '../components/icon/PauseIcon.astro';
---

<header class="header">
  <div class="inner">
    <p class="logo">WAAPI DEMO</p>
    <button class="motion-controller">
      <PlayIcon />
      <PauseIcon />
    </button>
  </div>
</header>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixin' as *;

  .header {
    position: fixed;
    z-index: 100;
    width: 100%;
    inset-inline: 0;
    top: 0;
    margin-inline: auto;
    padding: var(--spacing-sm) var(--spacing-lg);
    backdrop-filter: blur(0.5rem);
    opacity: 0; // 登場前の初期状態
    translate: 0 -50px;
  }

  .inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: var(--fz-xl);
    font-weight: 500;
    font-family: var(--font-secondary);
    letter-spacing: 0;
    line-height: 1ch;
  }
</style>

<script>
  // ① ヘッダーの登場: opacity 0 / y:-50px から降りてくる
  // Loader の完了（loader:finished）を受け取ってから再生する
  const header = document.querySelector<HTMLElement>('.header');
  window.addEventListener(
    'loader:finished',
    () => {
      header?.animate(
        { opacity: [0, 1], translate: ['0 -50px', '0 0'] },
        { duration: 800, easing: 'ease-out', fill: 'both' },
      );
    },
    { once: true },
  );
</script>
