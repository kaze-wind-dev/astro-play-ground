---
import Layout from '@/layout/Layout.astro';
import Section from '@/components/Section.astro';
import PageTitle from '@/components/PageTitle.astro';
import Heading2 from '@/components/Heading2.astro';
const pageTitle = '';
---

<Layout pageTitle={pageTitle}>
  <div class="side-menu">
    <ul class="list">
      <li class="item">
        <a href="#section-01" class="link" data-anchor>Section01</a>
      </li>
      <li class="item">
        <a href="#section-02" class="link" data-anchor>Section02</a>
      </li>
      <li class="item">
        <a href="#section-03" class="link" data-anchor>Section03</a>
      </li>
      <li class="item">
        <a href="#section-04" class="link" data-anchor>Section04</a>
      </li>
      <li class="item">
        <a href="#section-05" class="link" data-anchor>Section05</a>
      </li>
    </ul>
  </div>
  <PageTitle title={pageTitle} />
  <Section class="section-01" data-scroll-trigger data-theme="lightgray">
    <Heading2 title="Section01" />
  </Section>
  <Section class="section-02" data-scroll-trigger data-theme="black">
    <Heading2 title="Section02" />
  </Section>
  <Section class="section-03" data-scroll-trigger data-theme="bg">
    <Heading2 title="Section03" />
  </Section>
  <Section class="section-04" data-scroll-trigger data-theme="lightgray">
    <Heading2 title="Section04" />
  </Section>
  <Section class="section-05" data-scroll-trigger data-theme="black">
    <Heading2 title="Section05" />
  </Section>
  <Section class="section-06" data-scroll-trigger data-theme="bg">
    <Heading2 title="Section06" />
  </Section>
</Layout>

<style lang="scss">
  @use '@/styles/variables' as *;
  @use '@/styles/mixin' as *;
  @use '@/styles/functions' as *;

  :root {
    --_main-inline-padding: 0;
  }

  .side-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 80px;
    height: 100%;
    color: var(--black-color);
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .item {
    font-weight: 700;
  }

  .link {
    text-decoration: none;
    height: 80px;
    color: var(--black-color);
    display: block;
    border-radius: rem(4);
    font-size: var(--font-size-xs);
    text-align: center;
    place-content: center;
    transition: color 0.3s ease;

    &.-current {
      background-color: var(--secondary-color);
      color: var(--white-color);
    }

    @include hover {
      background-color: var(--secondary-color);
      color: var(--white-color);
    }
  }

  .section-01,
  .section-02,
  .section-03,
  .section-04,
  .section-05,
  .section-06 {
    height: 80dvh;
    text-align: center;
    margin-bottom: 0 !important;
  }

  .section-01,
  .section-04 {
    background-color: var(--light-gray-color);
  }

  .section-02,
  .section-05 {
    background-color: var(--black-color);
    color: var(--white-color);
  }

  .section-03,
  .section-06 {
    background-color: var(--bg-color);
  }
</style>

<script>
  /*
   * 実装方針についてまとめる
   *
   * セクションとリンクにdata属性を付与し、JSで取得する
   * セクションの方には、data-theme定義しておき、この色に合わせてリンクの色を変更する
   *
   * セクションとリンクの矩形の中心を取り、その座標を取得する
   * セクションの矩形とリンクの中心の距離が近くなれば、リンクの色を変更する
   *
   * カレント表示の要素は色変更しない
   *
   * スクロール時と、リサイズ時にも実行する（リサイズ時に実行されないことがあるため、スクロール時のみではなく、リサイズ時も実行する）
   *
   * あとは頑張って書く！
   * もっと他のやり方もないか検討する
   */

  const targets = Array.from(
    document.querySelectorAll('[data-scroll-trigger]'),
  );
  const anchors = Array.from(document.querySelectorAll('[data-anchor]'));

  const mediaQuery: MediaQueryList = window.matchMedia('(min-width: 768px)');

  const colorSchemes = {
    white: 'var(--white-color)',
    lightgray: 'var(--black-color)',
    black: 'var(--white-color)',
    bg: 'var(--black-color)',
  } as const;

  type Scheme = keyof typeof colorSchemes;

  type AnchorCenter = {
    center: number;
    anchor: HTMLElement;
  };

  const getAnchorCenters = (): AnchorCenter[] => {
    return anchors.map((anchor): AnchorCenter => {
      const rect = anchor.getBoundingClientRect();
      return {
        center: rect.top + rect.height / 2,
        anchor: anchor as HTMLElement,
      };
    });
  };

  const matchColor = (el: HTMLElement): (typeof colorSchemes)[Scheme] => {
    const scheme = el.dataset.theme as Scheme;
    return scheme && scheme in colorSchemes
      ? colorSchemes[scheme]
      : colorSchemes.white;
  };

  function updateAnchorColors(): void {
    const snapshots = snapshotTargets();
    if (!snapshots) return;
    const anchorCenters = getAnchorCenters();
    snapshots.forEach((snapshot) => {
      anchorCenters.forEach((anchorCenter) => {
        if (
          snapshot.top <= anchorCenter.center &&
          snapshot.bottom >= anchorCenter.center
        ) {
          anchorCenter.anchor.style.color = snapshot.scheme;
        }
      });
    });
  }

  type Output = {
    top: number;
    bottom: number;
    scheme: (typeof colorSchemes)[Scheme];
  };
  function snapshotTargets(): Output[] {
    if (targets.length === 0 || anchors.length === 0) return [];
    const output: Output[] = [];
    for (const target of targets) {
      const rect = target.getBoundingClientRect();
      if (!(target instanceof HTMLElement)) continue;
      const matchedColor = matchColor(target);
      output.push({
        top: rect.top,
        bottom: rect.bottom,
        scheme: matchedColor,
      });
    }
    return output;
  }

  let rafId: number | null = null;

  function requestUpdateAnchorColors(): void {
    if (!mediaQuery.matches) return;
    if (rafId !== null) return;
    rafId = window.requestAnimationFrame(() => {
      rafId = null;
      updateAnchorColors();
    });
  }

  const addDesktopListeners = () => {
    window.addEventListener('scroll', requestUpdateAnchorColors, {
      passive: true,
    });
    window.addEventListener('resize', requestUpdateAnchorColors);
    requestUpdateAnchorColors();
  };

  const removeDesktopListeners = () => {
    window.removeEventListener('scroll', requestUpdateAnchorColors);
    window.removeEventListener('resize', requestUpdateAnchorColors);
    console.log('removeDesktopListeners');
  };

  if (mediaQuery.matches) {
    addDesktopListeners();
  } else {
    removeDesktopListeners();
  }

  mediaQuery.addEventListener('change', (e) => {
    if (e.matches) {
      addDesktopListeners();
    } else {
      removeDesktopListeners();
    }
  });

